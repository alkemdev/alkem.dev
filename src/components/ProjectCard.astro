---
import MagicalCard from './MagicalCard.astro'

interface Props {
  title: string
  blurb: string
  slug: string
  status?: string
  tags?: string[]
}

const { title, blurb, slug, status = 'active', tags = [] } = Astro.props

const statusStyle: Record<string, string> = {
  active: 'border-green/30 bg-green/10 text-green',
  completed: 'border-border bg-bg text-text-dim',
  planned: 'border-purple/30 bg-purple/10 text-purple',
}
---

<MagicalCard href={`/code/${slug}`} glow="purple">
  <div class="mb-3 flex items-start justify-between gap-3">
    <h3 class="text-xl font-bold text-text transition-colors group-hover:text-purple">{title}</h3>
    <span
      class:list={[
        'shrink-0 rounded-full border px-2 py-0.5 font-mono text-[10px] tracking-wider uppercase',
        statusStyle[status] ?? statusStyle.completed,
      ]}
    >
      {status}
    </span>
  </div>
  <p class="flex-grow text-sm text-text-dim">{blurb}</p>
  {
    tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="rounded-full border border-border/60 bg-bg-raised/60 px-2 py-0.5 font-mono text-[10px] tracking-wide text-text-dim">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</MagicalCard>

---
import Root from './Root.astro'
import Nav from '@components/Nav.astro'
import Footer from '@components/Footer.astro'

interface Props {
  title: string
  blurb: string
  dated: Date
  image?: string | undefined
  tags?: string[] | undefined
}

const { title, blurb, dated, image, tags = [] } = Astro.props
---

<Root title={title} description={blurb} image={image}>
  <Nav />
  <main id="main-content" tabindex="-1" class="mx-auto max-w-3xl px-6 pt-24 pb-16 outline-none">
    <article>
      <nav aria-label="Breadcrumb" class="mb-10">
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 rounded-md text-sm text-text-dim transition-colors hover:text-green focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green"
        >
          <svg
            class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
          </svg>
          All posts
        </a>
      </nav>
      <header class="mb-12">
        <time datetime={dated.toISOString()} class="text-sm text-text-dim">
          {dated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="mt-2 text-4xl font-bold leading-tight">{title}</h1>
        <p class="mt-4 text-lg text-text-dim">{blurb}</p>
        {
          tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-full bg-bg-raised px-3 py-1 text-xs text-text-dim">{tag}</span>
              ))}
            </div>
          )
        }
      </header>
      <div
        class="prose prose-invert max-w-none prose-headings:text-text prose-a:text-green prose-code:text-purple prose-pre:bg-bg-raised prose-pre:border prose-pre:border-border"
      >
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</Root>

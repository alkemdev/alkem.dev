---
interface Props {
  title?: string
  class?: string
  id?: string
  variant?: 'plain' | 'surface'
}

const { title, class: className, id, variant = 'plain' } = Astro.props

const isSurface = variant === 'surface'
---

<section
  id={id}
  class:list={[
    'scroll-mt-24',
    isSurface
      ? 'rounded-2xl border border-border/50 bg-bg-raised/45 p-8 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05),0_12px_40px_-20px_rgba(0,0,0,0.45)] md:p-11'
      : '',
    !isSurface && 'py-12 md:py-16',
    className,
  ]}
>
  {
    title && (
      <div class="mb-8 md:mb-10">
        <h2 class="text-3xl font-bold tracking-tight text-text md:text-4xl">{title}</h2>
        <div
          class="mt-3 h-0.5 w-10 rounded-full bg-green/45 md:mt-3.5 md:w-12"
          aria-hidden="true"
        />
      </div>
    )
  }
  <slot />
</section>

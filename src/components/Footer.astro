---
import { SITE, NAV_LINKS } from '@/site'
---

<footer class="border-t border-border/50 py-14">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <p class="font-semibold text-text">{SITE.name}</p>
        <p class="mt-2 text-sm leading-relaxed text-text-dim">{SITE.description}</p>
      </div>
      <nav class="flex flex-wrap gap-x-8 gap-y-3 text-sm" aria-label="Footer">
        {
          NAV_LINKS.map((link) => (
            <a href={link.href} class="text-text-dim transition-colors hover:text-green">
              {link.label}
            </a>
          ))
        }
        <a href={SITE.socials.github} class="text-text-dim transition-colors hover:text-green">
          GitHub
        </a>
        <a href="/rss.xml" class="text-text-dim transition-colors hover:text-green"> RSS </a>
      </nav>
    </div>
    <p class="mt-10 border-t border-border/40 pt-8 text-center text-sm text-text-dim md:text-left">
      &copy; {new Date().getFullYear()}
      {SITE.name}
    </p>
  </div>
</footer>

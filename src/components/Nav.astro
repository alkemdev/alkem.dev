---
import { SITE, NAV_LINKS } from '@/site'

const pathname = Astro.url.pathname
---

<nav
  class="fixed top-0 z-50 w-full border-b border-border/50 bg-bg/80 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2 text-text hover:text-green">
      <img src="/images/flask.svg" alt="" class="h-8 w-8" />
      <span class="text-lg font-bold">{SITE.name}</span>
    </a>

    <div class="flex items-center gap-8">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm transition-colors',
              pathname.startsWith(link.href)
                ? 'text-green'
                : 'text-text-dim hover:text-text',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

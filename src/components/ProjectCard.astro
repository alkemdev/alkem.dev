---
interface Props {
  title: string
  blurb: string
  slug: string
  status?: string
  tags?: string[]
}

const { title, blurb, slug, status = 'active', tags = [] } = Astro.props

const statusColor: Record<string, string> = {
  active: 'text-green',
  completed: 'text-text-dim',
  planned: 'text-purple',
}
---

<a
  href={`/code/${slug}`}
  class="magical-card group relative block h-full overflow-hidden rounded-xl bg-bg-raised p-[1px] shadow-[0_2px_10px_rgba(0,0,0,0.3)] transition-all duration-200 ease-out hover:shadow-[0_10px_30px_rgba(96,168,121,0.08),0_10px_30px_rgba(153,85,187,0.08)]"
>
  <div
    class="magical-glow pointer-events-none absolute top-[-50%] left-[-50%] h-[200%] w-[200%] opacity-0 transition-opacity duration-500 bg-[conic-gradient(transparent,transparent,transparent,rgba(153,85,187,0.6),rgba(96,168,121,0.6),transparent)]"
    style="animation: rotate 6s linear infinite;"
  >
  </div>

  <div
    class="magical-card-inner relative z-10 flex h-full flex-col rounded-[11px] bg-bg-raised p-6"
  >
    <div class="mb-2 flex items-center justify-between">
      <h3 class="text-xl font-bold text-text transition-colors group-hover:text-purple">{title}</h3>
      <span class:list={['text-xs capitalize', statusColor[status] ?? 'text-text-dim']}>
        {status}
      </span>
    </div>
    <p class="flex-grow text-sm text-text-dim">{blurb}</p>
    {
      tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded-full bg-bg px-2 py-0.5 text-xs text-text-dim">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>

<style>
  @keyframes rotate {
    100% {
      transform: rotate(360deg);
    }
  }
  .magical-card .magical-glow {
    animation-play-state: paused;
  }
  .magical-card:hover .magical-glow {
    opacity: 1;
    animation-play-state: running;
  }
</style>

---
import { SITE } from '@/site'
---

<footer class="border-t border-border/50 py-12">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 text-sm text-text-dim">
    <span>&copy; {new Date().getFullYear()} {SITE.name}</span>
    <div class="flex items-center gap-6">
      <a href={SITE.socials.github} class="hover:text-text">GitHub</a>
      <a href="/rss.xml" class="hover:text-text">RSS</a>
    </div>
  </div>
</footer>

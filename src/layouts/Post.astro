---
import 'katex/dist/katex.min.css'
import Root from './Root.astro'
import Nav from '@components/Nav.astro'
import Footer from '@components/Footer.astro'
import { SITE, canonicalPath } from '@/site'

interface Props {
  title: string
  blurb: string
  dated: Date
  image?: string | undefined
  tags?: string[] | undefined
  minutes?: number | undefined
}

const { title, blurb, dated, image, tags = [], minutes } = Astro.props

const canonicalUrl = new URL(canonicalPath(Astro.url.pathname), SITE.url).toString()
const ogImage = new URL(image ?? '/og.png', SITE.url).toString()

const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: blurb,
  datePublished: dated.toISOString(),
  url: canonicalUrl,
  mainEntityOfPage: canonicalUrl,
  image: ogImage,
  keywords: tags,
  author: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: new URL('/og.png', SITE.url).toString() },
  },
}
---

<Root title={title} description={blurb} image={image}>
  <Nav />
  <main id="main-content" tabindex="-1" class="mx-auto max-w-3xl px-6 pt-24 pb-16 outline-none">
    <article>
      <nav aria-label="Breadcrumb" class="mb-10">
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 rounded-md text-sm text-text-dim transition-colors hover:text-green focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green"
        >
          <svg
            class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
          </svg>
          All posts
        </a>
      </nav>
      <header class="mb-12">
        <p class="flex items-center gap-2 text-sm text-text-dim">
          <time datetime={dated.toISOString()}>
            {dated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {
            minutes && (
              <>
                <span aria-hidden="true" class="text-text-dim/50">
                  ·
                </span>
                <span>{minutes} min read</span>
              </>
            )
          }
        </p>
        <h1 class="mt-2 text-4xl font-bold leading-[1.1] md:text-5xl">{title}</h1>
        <div
          class="mt-4 h-[3px] w-16 rounded-full bg-gradient-to-r from-green via-green/70 to-purple md:w-24"
          aria-hidden="true"
        >
        </div>
        <p class="mt-5 text-lg text-text-dim">{blurb}</p>
        {
          tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-1.5">
              {tags.map((tag) => (
                <span class="rounded-full border border-border/60 bg-bg-raised/60 px-2.5 py-0.5 font-mono text-[11px] tracking-wide text-text-dim">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>
      <div
        class="prose prose-invert max-w-none prose-headings:text-text prose-a:text-green prose-code:text-purple prose-pre:bg-bg-raised prose-pre:border prose-pre:border-border"
      >
        <slot />
      </div>
    </article>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingLd)} is:inline />
</Root>

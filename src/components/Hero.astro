---
import { SITE } from '@/site'
import { brand, hexToRgb } from '@/brand/colors'
import Button from './Button.astro'

const pr = hexToRgb(brand.purple)
const gr = hexToRgb(brand.green)

const fallbackBg = `radial-gradient(ellipse at 30% 50%, rgba(${pr.r},${pr.g},${pr.b},0.15) 0%, transparent 50%), radial-gradient(ellipse at 70% 50%, rgba(${gr.r},${gr.g},${gr.b},0.15) 0%, transparent 50%), ${brand.bg}`
---

<style>
  /* Use `svh` so mobile address-bar collapse does not retrigger layout
     (`dvh` recalculates on scroll and causes visible jank). */
  .hero {
    min-height: 100svh;
  }
  @supports not (height: 100svh) {
    .hero {
      min-height: 100vh;
    }
  }

  /* Staggered entrance — wordmark first, tagline + CTAs follow.
     `backwards` fill keeps the element invisible before its delay fires
     (no flash of unstaged content). */
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero-rise {
    animation: hero-rise 0.85s cubic-bezier(0.2, 0.8, 0.2, 1) backwards;
  }
  .hero-rise-1 {
    animation-delay: 0.05s;
  }
  .hero-rise-2 {
    animation-delay: 0.2s;
  }
  .hero-rise-3 {
    animation-delay: 0.4s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-rise {
      animation: none;
    }
  }
</style>

<section
  class="hero relative flex flex-col items-center justify-center overflow-hidden pb-16 md:pb-20"
  id="hero"
  aria-labelledby="hero-title"
>
  <canvas
    id="hero-canvas"
    class="absolute inset-0 h-full w-full"
    aria-hidden="true"
    role="presentation"></canvas>

  <div
    id="hero-fallback"
    class="absolute inset-0"
    style={`background: ${fallbackBg}`}
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-10 flex max-w-3xl flex-col items-center px-6 text-center"
    style="text-shadow: 0 0 20px rgba(10,10,15,0.9), 0 0 40px rgba(10,10,15,0.7);"
  >
    <h1
      id="hero-title"
      class="text-4xl font-bold leading-[1.05] sm:text-5xl md:text-7xl"
      style="text-shadow: 0 2px 30px rgba(10,10,15,0.95), 0 0 60px rgba(10,10,15,0.8);"
    >
      {
        SITE.wordmark.map((line, i) => (
          <span
            class:list={[
              'hero-rise',
              i === 0 ? 'hero-rise-1' : 'hero-rise-2',
              line.accent === 'green' ? 'text-green' : 'text-purple',
            ]}
            style="display: inline-block;"
          >
            {line.text}
            {i === 0 ? ' ' : ''}
          </span>
        ))
      }
    </h1>
    <div class="hero-rise hero-rise-3 mt-12 flex flex-wrap justify-center gap-4">
      <Button href="/blog" variant="primary" size="lg">
        Read Blog <span class="btn-arrow" aria-hidden="true">→</span>
      </Button>
      <Button href="/info" variant="secondary" size="lg">
        About Us <span class="btn-arrow" aria-hidden="true">→</span>
      </Button>
    </div>
  </div>
</section>

<script>
  async function initHero() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null
    const fallback = document.getElementById('hero-fallback')
    if (!canvas) return

    try {
      const { HeroScene } = await import('@three/scene')
      const scene = new HeroScene(canvas)

      const { initScrollAnimation } = await import('@three/scroll')
      const trigger = initScrollAnimation(scene)

      if (fallback) fallback.style.display = 'none'

      // `once` pairs each init with exactly one cleanup — no listener accumulation
      // across view transitions.
      document.addEventListener(
        'astro:before-swap',
        () => {
          trigger?.kill()
          scene.dispose()
        },
        { once: true },
      )
    } catch (e) {
      console.warn('[hero] WebGL init failed, using CSS fallback:', e)
    }
  }

  initHero()
  document.addEventListener('astro:after-swap', initHero)
</script>

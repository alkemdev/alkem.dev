---
interface Props {
  title?: string
  class?: string
  id?: string
  variant?: 'plain' | 'surface'
}

const { title, class: className, id, variant = 'plain' } = Astro.props

const isSurface = variant === 'surface'
---

<section
  id={id}
  class:list={[
    'scroll-mt-24',
    isSurface
      ? 'rounded-2xl border border-border/50 bg-bg-raised/45 p-5 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05),0_18px_50px_-25px_rgba(0,0,0,0.55)] backdrop-blur-sm sm:p-7 md:p-11'
      : '',
    !isSurface && 'py-10 md:py-16',
    className,
  ]}
>
  {
    title && (
      <h2 class="mb-8 text-3xl font-bold tracking-tight text-text md:mb-10 md:text-4xl">{title}</h2>
    )
  }
  <slot />
</section>

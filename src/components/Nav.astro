---
import { SITE, NAV_LINKS } from '@/site'

const pathname = Astro.url.pathname

const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`)

const linkClass = (href: string) =>
  [
    'rounded-md px-2 py-1.5 text-sm transition-colors',
    isActive(href) ? 'text-green' : 'text-text-dim hover:text-text',
  ] as const
---

<nav
  class="nav-fixed fixed top-0 z-50 w-full border-b border-border/50 bg-bg/80 backdrop-blur-md"
  aria-label="Primary"
>
  <div class="relative mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a
      href="/"
      class="flex items-center gap-2 rounded-md text-text outline-offset-4 hover:text-green focus-visible:outline focus-visible:outline-2 focus-visible:outline-green"
    >
      <img src="/images/flask.svg" alt="" width="32" height="32" class="h-8 w-8" />
      <span class="text-lg font-bold">{SITE.name}</span>
    </a>

    <div class="hidden items-center gap-2 md:flex">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={linkClass(link.href)}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <button
      type="button"
      id="nav-menu-btn"
      class="inline-flex items-center justify-center rounded-lg border border-border p-2 text-text-dim hover:border-green hover:text-text md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Open menu"
    >
      <svg
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-nav"
    class="absolute left-0 right-0 top-full z-40 hidden flex-col gap-1 border-b border-border/50 bg-bg/95 px-6 py-4 backdrop-blur-md md:hidden"
  >
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[...linkClass(link.href), 'py-2']}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </div>
</nav>

<script>
  let navGlobalsWired = false

  function closeMobileNav() {
    const panel = document.getElementById('mobile-nav')
    const btn = document.getElementById('nav-menu-btn')
    panel?.classList.add('hidden')
    btn?.setAttribute('aria-expanded', 'false')
    btn?.setAttribute('aria-label', 'Open menu')
  }

  function wireMobileNav() {
    const btn = document.getElementById('nav-menu-btn')
    const panel = document.getElementById('mobile-nav')
    if (!(btn instanceof HTMLElement) || !(panel instanceof HTMLElement)) return
    if (btn.dataset.wired === '1') return
    btn.dataset.wired = '1'

    const menuBtn = btn
    const menuPanel = panel

    function openMenu() {
      menuPanel.classList.remove('hidden')
      menuBtn.setAttribute('aria-expanded', 'true')
      menuBtn.setAttribute('aria-label', 'Close menu')
    }

    function closeMenu() {
      menuPanel.classList.add('hidden')
      menuBtn.setAttribute('aria-expanded', 'false')
      menuBtn.setAttribute('aria-label', 'Open menu')
    }

    menuBtn.addEventListener('click', () => {
      if (menuPanel.classList.contains('hidden')) openMenu()
      else closeMenu()
    })

    menuPanel.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu))

    if (!navGlobalsWired) {
      navGlobalsWired = true
      window.addEventListener('resize', () => {
        if (window.matchMedia('(min-width: 768px)').matches) closeMobileNav()
      })
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMobileNav()
      })
    }
  }

  wireMobileNav()
  document.addEventListener('astro:page-load', wireMobileNav)
</script>

<style>
  /* Promote to its own compositing layer so backdrop-filter doesn't repaint
     the viewport on every scroll frame (iOS Safari especially). */
  .nav-fixed {
    transform: translateZ(0);
    will-change: transform;
  }
</style>

---
/**
 * Card shell with a rotating conic-gradient halo on hover.
 * Pass `href` to render as `<a>`; omit for a non-linking `<div>`.
 * `glow` picks the gradient direction (green-first vs purple-first).
 *
 * Brand colors flow through CSS vars: the component sets
 * `--magical-from` / `--magical-to` to two of the @theme tokens, and
 * the conic-gradient + hover shadow are defined in global.css.
 */
interface Props {
  href?: string | undefined
  glow?: 'green' | 'purple'
  class?: string | undefined
}

const { href, glow = 'purple', class: className } = Astro.props
const Tag = href ? 'a' : 'div'

const glowVars =
  glow === 'green'
    ? '--magical-from: var(--color-green); --magical-to: var(--color-purple);'
    : '--magical-from: var(--color-purple); --magical-to: var(--color-green);'
---

<Tag
  href={href}
  style={glowVars}
  class:list={[
    'magical-card group relative block h-full overflow-hidden rounded-xl bg-bg-raised p-[1px] transition-all duration-200 ease-out',
    className,
  ]}
>
  <div
    class="magical-glow pointer-events-none absolute top-[-50%] left-[-50%] h-[200%] w-[200%] opacity-0 transition-opacity duration-500"
    aria-hidden="true"
  >
  </div>
  <div
    class="magical-card-inner relative z-10 flex h-full flex-col rounded-[11px] bg-bg-raised p-6"
  >
    <slot />
  </div>
</Tag>

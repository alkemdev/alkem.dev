---
import Page from '@layouts/Page.astro'
import PostCard from '@components/PostCard.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.dated.getTime() - a.data.dated.getTime())
---

<Page title="Blog" description="Technical writing from Alkemical Development.">
  <h1 class="mb-10 text-4xl font-bold">Blog</h1>
  {
    posts.length === 0 ? (
      <p class="text-text-dim">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            blurb={post.data.blurb}
            slug={post.id}
            dated={post.data.dated}
            tags={post.data.tags}
          />
        ))}
      </div>
    )
  }
</Page>

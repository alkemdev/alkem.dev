---
import Page from '@layouts/Page.astro'
import TeamCard from '@components/TeamCard.astro'
import { SITE } from '@/site'
import { getCollection } from 'astro:content'

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order)
---

<Page title={SITE.pages.info.title} description={SITE.pages.info.description}>
  <h1 class="mb-10 text-4xl font-bold">{SITE.pages.info.title}</h1>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      team.map((member) => (
        <TeamCard
          name={member.data.name}
          role={member.data.role}
          blurb={member.data.blurb}
          image={member.data.image}
          socials={member.data.socials}
        />
      ))
    }
  </div>
</Page>

---
import Page from '@layouts/Page.astro'
---

<Page title="404 — Not Found" description="The page you’re looking for doesn’t exist.">
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center">
    <p class="font-mono text-sm tracking-widest text-text-dim uppercase">Error 404</p>
    <h1 class="mt-3 text-5xl font-bold leading-[1.05] sm:text-6xl md:text-7xl">
      <span class="text-green">Path</span>
      <span class="text-purple">not found</span>
    </h1>
    <p class="mt-6 max-w-md text-text-dim">
      Either the page never existed, or it’s been moved. Try the links below or head home.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/"
        class="rounded-lg bg-purple px-6 py-3 text-sm font-bold text-white transition-opacity hover:opacity-95 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green"
      >
        Home
      </a>
      <a
        href="/blog"
        class="rounded-lg border border-border bg-bg/40 px-6 py-3 text-sm font-bold text-text backdrop-blur-sm transition-colors hover:border-green hover:text-green focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple"
      >
        Blog
      </a>
      <a
        href="/code"
        class="rounded-lg border border-border bg-bg/40 px-6 py-3 text-sm font-bold text-text backdrop-blur-sm transition-colors hover:border-green hover:text-green focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple"
      >
        Code
      </a>
    </div>
  </div>
</Page>

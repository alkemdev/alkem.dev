---
import { SITE, NAV_LINKS } from '@/site'
---

<footer class="relative mt-20 border-t border-border/50 py-16 md:py-20">
  <div
    aria-hidden="true"
    class="absolute -top-px left-1/2 h-px w-32 -translate-x-1/2 bg-gradient-to-r from-transparent via-purple/40 to-transparent"
  >
  </div>
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center gap-8 text-center">
      <a
        href="/"
        class="group flex flex-col items-center gap-3 transition-colors hover:opacity-90"
        aria-label="Home"
      >
        <img
          src="/images/flask.svg"
          alt=""
          width="40"
          height="40"
          class="h-10 w-10"
          aria-hidden="true"
        />
        <span class="text-xl font-bold tracking-tight">{SITE.name}</span>
      </a>

      <nav
        aria-label="Footer"
        class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-text-dim"
      >
        {
          NAV_LINKS.map((link) => (
            <a href={link.href} class="transition-colors hover:text-green">
              {link.label}
            </a>
          ))
        }
        <a href={SITE.socials.github} class="transition-colors hover:text-green">GitHub</a>
        <a href="/rss.xml" class="transition-colors hover:text-green">RSS</a>
      </nav>

      <p class="text-xs text-text-dim/70">
        &copy; {new Date().getFullYear()} {SITE.name}
      </p>
    </div>
  </div>
</footer>
